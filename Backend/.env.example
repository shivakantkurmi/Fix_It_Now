# Backend environment variables
# Copy this file to .env and fill in your real values.
# .env is gitignored — NEVER commit it.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ── MongoDB Atlas ────────────────────────────────────────────────────────────
# MongoDB Atlas → Cluster → Connect → Drivers → copy connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/fixitnow?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# ── Frontend origin (for CORS) ───────────────────────────────────────────────
# Local:      http://localhost:5173
# Production: https://your-frontend.vercel.app
CLIENT_URL=http://localhost:5173

# ── Google Gemini API ────────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── ML Service ───────────────────────────────────────────────────────────────
# Local (start FastAPI first):  http://localhost:5001
# Vercel (after deploying):     https://your-backend.vercel.app/ml
ML_SERVICE_URL=http://localhost:5001

# ── Super Admin (seeded automatically on first server start) ─────────────────
# These credentials are used ONCE to create the top-level authority account.
# After creation, the account exists in MongoDB — changing these values here
# will NOT update the existing account (only affects a fresh database).
SUPERADMIN_EMAIL=superadmin@fixitnow.gov.in
SUPERADMIN_PASSWORD=ChangeMe@123
SUPERADMIN_NAME=Super Admin

