{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/predict-priority.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/ml/predict-priority",
      "dest": "api/predict-priority.py"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}